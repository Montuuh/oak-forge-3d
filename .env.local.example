# Oak's Forge 3D - Environment Variables

# N3D Melbourne API Key
# Get yours at: https://n3dmelbourne.com → Dashboard → Tools → Design API
N3D_API_KEY=n3d_sk_your_key_here
# Límite de tu tier Patreon (casual = 5/min). Sube el valor si tu key permite más.
N3D_API_REQUESTS_PER_MIN=5

# Postgres connection string (Supabase)
# Example format:
# For Supabase pooler use:
# postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require&uselibpqcompat=true&pgbouncer=true
# Required at runtime (admin/API). Vercel: add in Project → Settings → Environment Variables.
# Build uses a placeholder if missing during prisma generate.
DATABASE_URL=postgresql://postgres.your_ref:your_password@aws-0-your-region.pooler.supabase.com:6543/postgres?sslmode=require&uselibpqcompat=true&pgbouncer=true

# Conexión directa para migraciones DDL (puerto 5432). Supabase → Settings → Database → URI
DIRECT_URL=postgresql://postgres:your_password@db.your_ref.supabase.co:5432/postgres?sslmode=require

# Catalogo publico: siempre Postgres (DATABASE_URL obligatorio)
# CATALOG_SOURCE=db

# Admin access (owner mode)
ADMIN_PASSWORD=change_this_password
ADMIN_SESSION_SECRET=change_this_to_a_long_random_secret
ADMIN_REVIEWER_NAME=dmont

# Supabase Storage (server-only; Project Settings > API > service_role)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=product-images

# Google AI (Gemini / Imagen) — generacion de imagenes en admin
# API key: https://aistudio.google.com/app/apikey (misma cuenta que Google AI Pro)
GEMINI_API_KEY=
# imagen (default) = Imagen 4, solo prompt texto | gemini = envia fotos de referencia (prepago)
GOOGLE_IMAGE_BACKEND=imagen
GOOGLE_IMAGE_MODEL=imagen-4.0-fast-generate-001
# Solo si GOOGLE_IMAGE_BACKEND=gemini:
# GOOGLE_IMAGE_MODEL=gemini-2.5-flash-image

# Proveedor de generacion en admin: vertex (GCP billing) | aistudio (AI Studio Prepay)
IMAGE_PROVIDER=vertex
# Vertex AI (experimental) — usa creditos GCP, no Prepay de AI Studio
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=europe-west1
# Local: gcloud auth application-default login
# Vercel/produccion: pega el JSON completo de la service account (una linea o multiline en el panel)
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# VERTEX_IMAGE_BACKEND=gemini
# VERTEX_IMAGE_MODEL=gemini-2.5-flash-image
# VERTEX_IMAGEN_MODEL=imagen-3.0-generate-002
# Salida Gemini (v7 usa 16:9 por defecto; resolucion 2K evita imagenes pequenas)
# GEMINI_IMAGE_SIZE=2K
# GEMINI_IMAGE_ASPECT_RATIO=16:9
# Modelo imagen Vertex (por defecto gemini-2.5-flash-image en europe-west1)
# VERTEX_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Nano Banana 2 en Vertex suele requerir endpoint global (no europe-west1):
# VERTEX_GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# VERTEX_IMAGE_USE_GLOBAL_LOCATION=true
# GOOGLE_CLOUD_LOCATION=global

# Prompt v7: ruta opcional a foto fija de estudio (mesa + gotelé). Si no, usa public/images/studio/default.*
# STUDIO_SCENE_IMAGE_PATH=/images/studio/default.jpg

# Imagenes de producto: siempre Supabase Storage (bucket product-images, publico)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=product-images
# Render N3D por producto: npm run sync:n3d-image -- <slug>

# Busqueda de imagenes de referencia en admin (hasta 50 resultados; UI pagina de 10 en 10)
# Google Custom Search JSON API esta CERRADA a proyectos nuevos (2025+).
# Recomendado: Serper (https://serper.dev — ~2500 busquedas gratis)
IMAGE_SEARCH_PROVIDER=serper
SERPER_API_KEY=
# Legacy (solo si ya tenias acceso antes de 2025):
# IMAGE_SEARCH_PROVIDER=google_cse
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_ID=
